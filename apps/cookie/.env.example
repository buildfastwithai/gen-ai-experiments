# Cookie AI Agent — Environment Configuration
# Copy this to .env and fill in your keys

# ═══════════════════════════════════════════
# LLM Provider API Keys
# ═══════════════════════════════════════════

# OpenAI
OPENAI_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini
GEMINI_API_KEY=

# Groq
GROQ_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# Ollama (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# LM Studio (default: http://localhost:1234)
LMSTUDIO_BASE_URL=http://localhost:1234

# Custom OpenAI-compatible endpoint
CUSTOM_API_KEY=
CUSTOM_BASE_URL=

# ═══════════════════════════════════════════
# Cookie Configuration
# ═══════════════════════════════════════════

# Default provider (openai | anthropic | gemini | groq | openrouter | ollama | lmstudio | custom)
COOKIE_DEFAULT_PROVIDER=openai

# Default model (provider-specific)
COOKIE_DEFAULT_MODEL=gpt-4o

# Safety mode (strict | normal | yolo)
COOKIE_SAFETY_MODE=normal

# Verbose logging
COOKIE_VERBOSE=false

# Memory persistence path (default: ~/.cookie/memory.db)
COOKIE_MEMORY_PATH=
